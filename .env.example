# Copy to .env — never commit real secrets

# API base URL without /api/v1 (added automatically in src/lib/env.ts)
VITE_API_BASE_URL=http://localhost:3001

# Optional: Socket.IO path if not default /socket.io
# VITE_SOCKET_PATH=/socket.io

# Production: set VITE_API_BASE_URL before `pnpm build` (e.g. https://api.your-domain.com)
